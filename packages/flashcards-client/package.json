{
  "name": "@heybray/flashcards-client",
  "version": "0.1.2",
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Flashcards deck domain — mountable client feature package (routes, pages, admin panels).",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybray-labs/bray-flashcards.git",
    "directory": "packages/flashcards-client"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src"
  ],
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./assets/*": "./src/assets/*",
    "./layout": {
      "types": "./src/layout-context.tsx",
      "default": "./src/layout-context.tsx"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@heybray/gamification": "^1.0.0",
    "@heybray/gamification-react": "^1.2.0",
    "@heybray/react": "^1.2.0",
    "@heybray/ui": "^1.0.0",
    "@tanstack/react-query": "^5.60.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "happy-dom": "^17.4.4",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.4"
  }
}
