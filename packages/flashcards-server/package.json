{
  "name": "@heybray/flashcards-server",
  "version": "0.1.2",
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Flashcards deck domain — mountable server feature package (routes, schema, seed).",
  "repository": {
    "type": "git",
    "url": "https://github.com/heybray-labs/bray-flashcards.git",
    "directory": "packages/flashcards-server"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "default": "./src/schema/*.ts"
    },
    "./team-star-map": {
      "types": "./src/team-star-map-handlers.ts",
      "default": "./src/team-star-map-handlers.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@heybray/gamification": "^1.0.0",
    "@heybray/identity": "^1.0.0",
    "@heybray/media": "^1.0.0",
    "@heybray/server-kit": "^1.0.0",
    "@heybray/taxonomy": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "typescript": "^5.6.3"
  }
}
