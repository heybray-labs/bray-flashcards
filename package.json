{
  "name": "bray-flashcards",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Flashcard/quiz trainer — Phase 5 platform validation app",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "dev:client": "vite --mode development",
    "build": "vite build",
    "start": "tsx --env-file=.env server/index.ts",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:init": "tsx --env-file=.env server/init-db.ts",
    "test": "./bin/test.sh",
    "test:api": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v --remove-orphans"
  },
  "dependencies": {
    "@heybray/flashcards-client": "^0.1.0",
    "@heybray/flashcards-server": "^0.1.0",
    "@heybray/gamification": "^1.0.0",
    "@heybray/gamification-react": "^1.0.0",
    "@heybray/identity": "^1.0.0",
    "@heybray/media": "^1.0.0",
    "@heybray/react": "^1.0.0",
    "@heybray/server-kit": "^1.0.0",
    "@heybray/taxonomy": "^1.0.0",
    "@heybray/ui": "^1.0.0",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "lucide-react": "^0.453.0",
    "multer": "^2.2.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "zod": "^3.25.76",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@heybray/dev-config": "^1.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.15.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.4",
    "supertest": "^7.1.4",
    "@types/supertest": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
